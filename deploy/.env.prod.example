# Image settings
APP_IMAGE=ghcr.io/your-org/speech_diarization_common
IMAGE_TAG=latest

# Public domain and TLS
APP_DOMAIN=speech.example.com
ACME_EMAIL=ops@example.com

# External services
DATABASE_URL=postgresql+asyncpg://db_user:db_pass@<postgres_ip_or_host>:5432/speech_diarization
REDIS_URL=redis://:redis_pass@<redis_ip_or_host>:6379/0

# App core
APP_TITLE=Speech_diarization
SECRET=replace-with-a-long-random-secret
FIRST_SUPERUSER_EMAIL=
FIRST_SUPERUSER_PASSWORD=
LOG_LEVEL=INFO
COOKIE_SECURE=true
ALLOW_HTTP_WEBHOOKS=false
ALLOW_PRIVATE_WEBHOOK_HOSTS=false

# Timeweb S3
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=

# Transcription providers
TRANSCRIPTION_PROVIDER=elevenlabs
TRANSCRIPTION_FALLBACKS=gemini
ELEVENLABS_API_KEY=
ELEVENLABS_PROXY_URL=socks5://user:pass@host:port
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-3-flash-preview
GEMINI_PROMPT=
GEMINI_RESPONSE_JSON=true
GEMINI_TEMPERATURE=0
GEMINI_TOP_P=1
GEMINI_TIMEOUT_SECONDS=60
GEMINI_MAX_OUTPUT_TOKENS=0

# Optional legacy/extra providers
OPENAI_API_KEY=
WHISPER_API_URL=
HF_TOKEN=
